# ===========================
# Root .gitignore for Questify
# ===========================

# ---- Dependencies ----
node_modules/

# ---- Environment Variables (NEVER commit secrets!) ----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ---- Build Outputs ----
dist/
dist-ssr/
build/

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor / IDE ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Temporary / Misc Files ----
tmp_*.json
*.tmp
*.bak
*.pdf

# ---- Coverage / Testing ----
coverage/
.nyc_output/
