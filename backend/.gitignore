# ===========================
# Backend .gitignore
# ===========================

# ---- Dependencies ----
node_modules/

# ---- Environment Variables ----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ---- OS Files ----
.DS_Store
Thumbs.db

# ---- Temporary / Upload Files ----
tmp_*.json
uploads/
*.tmp
*.bak

# ---- Test / Debug Files ----
test.pdf
*.pdf

# ---- Editor / IDE ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?
